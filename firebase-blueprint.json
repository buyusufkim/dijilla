{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user-specific information and settings.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "The unique ID of the user (matches Firebase Auth UID)." },
        "full_name": { "type": "string", "description": "The user's full name." },
        "email": { "type": "string", "format": "email", "description": "The user's email address." },
        "points": { "type": "number", "description": "Gamification points earned by the user." },
        "notification_settings": {
          "type": "object",
          "properties": {
            "insurance_expiry": { "type": "boolean", "description": "Enable/disable insurance expiry notifications." },
            "inspection_reminders": { "type": "boolean", "description": "Enable/disable inspection reminder notifications." },
            "service_alerts": { "type": "boolean", "description": "Enable/disable service alert notifications." }
          },
          "description": "User's notification preferences."
        },
        "created_at": { "type": "string", "format": "date-time", "description": "When the profile was created." }
      },
      "required": ["id", "email"]
    },
    "Vehicle": {
      "title": "Vehicle",
      "description": "Represents a vehicle owned by a user.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique ID of the vehicle." },
        "user_id": { "type": "string", "description": "The UID of the owner." },
        "plate": { "type": "string", "description": "The vehicle's license plate." },
        "brand_model": { "type": "string", "description": "The brand and model of the vehicle." },
        "year": { "type": "number", "description": "The manufacturing year." },
        "insurance_expiry": { "type": "string", "format": "date", "description": "Expiry date of the insurance." },
        "inspection_expiry": { "type": "string", "format": "date", "description": "Expiry date of the inspection." },
        "tax_status": { "type": "string", "description": "Status of the motor vehicle tax." },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["user_id", "plate", "brand_model"]
    },
    "Expense": {
      "title": "Expense",
      "description": "A financial expense related to a vehicle or asset.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "user_id": { "type": "string" },
        "vehicle_id": { "type": "string", "description": "Optional link to a specific vehicle." },
        "category": { "type": "string", "enum": ["fuel", "maintenance", "insurance", "other"] },
        "title": { "type": "string" },
        "amount": { "type": "number" },
        "expense_date": { "type": "string", "format": "date-time" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["user_id", "category", "title", "amount", "expense_date"]
    },
    "Document": {
      "title": "Document",
      "description": "A digital document stored in the glovebox.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "user_id": { "type": "string" },
        "vehicle_id": { "type": "string" },
        "type": { "type": "string", "enum": ["license", "insurance", "registration", "other"] },
        "title": { "type": "string" },
        "expiry_date": { "type": "string", "format": "date" },
        "status": { "type": "string", "enum": ["valid", "warning", "expired"] },
        "file_url": { "type": "string", "format": "uri" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["user_id", "type", "title", "expiry_date", "status"]
    },
    "ServiceRequest": {
      "title": "Service Request",
      "description": "A request for roadside assistance or other services.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "user_id": { "type": "string" },
        "type": { "type": "string", "description": "Type of service (e.g., tow-truck, sos)." },
        "status": { "type": "string", "enum": ["pending", "active", "completed", "cancelled"] },
        "location": { "type": "object", "properties": { "lat": { "type": "number" }, "lng": { "type": "number" } } },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["user_id", "type", "status"]
    },
    "MaintenanceRecord": {
      "title": "Maintenance Record",
      "description": "A record of past vehicle maintenance.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "user_id": { "type": "string" },
        "vehicle_id": { "type": "string" },
        "service_type": { "type": "string", "description": "e.g., Oil Change, Brake Check" },
        "mileage": { "type": "number" },
        "date": { "type": "string", "format": "date" },
        "cost": { "type": "number" },
        "notes": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["user_id", "vehicle_id", "service_type", "date"]
    },
    "MaintenanceAppointment": {
      "title": "Maintenance Appointment",
      "description": "A future maintenance appointment.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "user_id": { "type": "string" },
        "vehicle_id": { "type": "string" },
        "service_type": { "type": "string" },
        "appointment_date": { "type": "string", "format": "date-time" },
        "location": { "type": "string" },
        "status": { "type": "string", "enum": ["scheduled", "completed", "cancelled"] },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["user_id", "vehicle_id", "service_type", "appointment_date", "status"]
    }
  },
  "firestore": {
    "/profiles/{userId}": {
      "schema": "UserProfile",
      "description": "User profile documents."
    },
    "/vehicles/{vehicleId}": {
      "schema": "Vehicle",
      "description": "Vehicle documents."
    },
    "/expenses/{expenseId}": {
      "schema": "Expense",
      "description": "Expense records."
    },
    "/documents/{documentId}": {
      "schema": "Document",
      "description": "Digital documents."
    },
    "/service_requests/{requestId}": {
      "schema": "ServiceRequest",
      "description": "Roadside assistance requests."
    },
    "/maintenance_records/{recordId}": {
      "schema": "MaintenanceRecord",
      "description": "Past maintenance records."
    },
    "/maintenance_appointments/{appointmentId}": {
      "schema": "MaintenanceAppointment",
      "description": "Scheduled maintenance appointments."
    }
  }
}
