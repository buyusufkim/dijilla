{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "typecheck": "tsc --noEmit",
    "build": "npm run typecheck && vite build && esbuild server.ts --bundle --platform=node --outfile=server.cjs --format=cjs --external:vite",
    "start": "NODE_ENV=production node server.cjs",
    "clean": "rm -rf dist server.cjs",
    "lint": "npm run typecheck"
  },
  "dependencies": {
